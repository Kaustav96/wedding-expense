{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('bandBajaBudget/system/isAdmin').child(auth.uid).val() === true",
        ".write": "auth.uid === $uid"
      }
    },
    "bandBajaBudget": {
      "system": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "expenses": {
        "$side": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      },
      "sideBudgets": {
        "$side": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      },
      "defaultMemberCredentials": {
        ".read": false,
        ".write": false
      }
    }
  }
}

