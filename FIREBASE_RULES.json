{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "bandBajaBudget": {
      "expenses": {
        "$side": {
          ".read": "auth != null && root.child('users').child(auth.uid).child('side').val() === $side",
          ".write": "auth != null && root.child('users').child(auth.uid).child('side').val() === $side"
        }
      },
      "sideBudgets": {
        "$side": {
          ".read": "auth != null && root.child('users').child(auth.uid).child('side').val() === $side",
          ".write": "auth != null && root.child('users').child(auth.uid).child('side').val() === $side"
        }
      },
      "system": {
        ".read": false,
        ".write": false
      },
      "defaultMemberCredentials": {
        ".read": false,
        ".write": false
      }
    }
  }
}
